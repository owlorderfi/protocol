# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
dist-prod/
build/
.next/
.turbo/
out/
*.tsbuildinfo

# Foundry
contracts/cache/
contracts/out/
contracts/broadcast/
contracts/lib/

# Env & secrets
.env
.env.local
.env.*.local
*.env
*.env.*
# Templates (no secrets, public docs) are explicitly kept in git.
!*.env.example
!*.env.*.example
*.bak

# Belt-and-suspenders: anything that looks like a key file or wallet
# artefact stays out, even if dropped into the repo by mistake.
# `cast wallet import` defaults to wallet.json; never want that tracked.
*.pem
*.key
wallet*.json
secrets/
private_keys/

# IDE state — personal paths + sometimes secrets in workspace settings
.vscode/
.history/

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# IDE
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Coverage
coverage/
*.lcov

# Misc
.cache/
tmp/

# VSCode workspace files (personal, paths may not be portable)
*.code-workspace
docker/monitoring/.env

# ─── Internal / kitchen ──────────────────────────────────────────
# Operator-specific infrastructure, deployment scripts, internal
# planning + AI context. None of this belongs in the public repo —
# anyone forking only needs what's in apps/ + contracts/ + packages/.
# These paths stay on disk (the operator uses them) but git ignores
# them. Backed up via the user-wide /home/radu/ backup job.
CLAUDE.md
**/CLAUDE.md
ROADMAP.md
URLS.md
ops/
docs/
scripts/
docker/monitoring/
.claude/
