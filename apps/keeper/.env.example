# ─── Common (operator-wide, chain-independent) ───────────────────
DATABASE_URL="postgresql://polyorder:polyorder@localhost:5432/polyorder"

# Same keeper signer used on every chain. Must be authorized in the
# router on each chain via setKeeperAuthorization().
KEEPER_PRIVATE_KEY="0x..."

# Which chain THIS process operates against. One keeper process per
# chain via systemd: polyorder-keeper-base-sepolia.service has
# Environment=CHAIN_ID=84532, polyorder-keeper-polygon has
# Environment=CHAIN_ID=137, etc. All processes read this same file.
CHAIN_ID=84532

# ─── Per-chain deployments ────────────────────────────────────────
# Convention: CHAIN_<chainId>_<KEY>. The keeper picks the block
# matching its CHAIN_ID at startup. Adding a chain = add a new block,
# no code change. Comments document the human-readable name.

# Chain: Anvil fork of Polygon (local dev)
CHAIN_31337_RPC=http://127.0.0.1:8545
CHAIN_31337_ROUTER=0x0dCB59Abab79183649B16042b28749CBc8147ADc

# Chain: Base Sepolia (testnet)
CHAIN_84532_RPC=https://sepolia.base.org
CHAIN_84532_ROUTER=0x03e6478854a4b92af594b98Bb8C8E644f9f564C7

# Chain: Polygon mainnet (production — uncomment when deployed)
# CHAIN_137_RPC=https://polygon-rpc.com
# CHAIN_137_PRIVATE_RPC=https://polygon.fastlane.xyz    # MEV protection
# CHAIN_137_ROUTER=0x...

# Chain: Base mainnet (production — uncomment when deployed)
# CHAIN_8453_RPC=https://mainnet.base.org
# CHAIN_8453_ROUTER=0x...

# Chain: Arbitrum mainnet (production — uncomment when deployed)
# CHAIN_42161_RPC=https://arb1.arbitrum.io/rpc
# CHAIN_42161_ROUTER=0x...

# ─── Legacy single-chain vars (backwards-compat) ─────────────────
# If you don't use CHAIN_<id>_* blocks above, set these. The keeper
# uses them as fallback for the active CHAIN_ID. New deployments
# should prefer the per-chain blocks.
# RPC_URL=
# PRIVATE_RPC_URL=
# LIMIT_ORDER_ROUTER_ADDRESS=
# WS_RPC_URL=
ONEINCH_API_KEY=""

# ─── Operational tuning (chain-independent) ──────────────────────
POLL_INTERVAL_SECONDS=2          # how often to poll for triggered orders
MAX_CONCURRENT_ORDERS=5          # max parallel order executions per cycle
STUCK_EXECUTING_MINUTES=5        # threshold for stuck-order recovery
DRY_RUN=false                    # when true: check triggers but skip tx
LOG_LEVEL=info

# ─── Gas + tx replacement ────────────────────────────────────────
GAS_HEADROOM_MULT=1.5            # maxFee = baseFee × this + priority
GAS_BUMP_PCT=20                  # +X% gas on stuck-tx replacement
TX_REPLACE_AFTER_SEC=60          # wait this long before bumping
GAS_PRIORITY_FALLBACK_GWEI=30    # used when RPC estimateFeesPerGas returns nothing
MAX_FEE_PER_GAS_GWEI=500         # hard ceiling — process aborts above this

# ─── Slippage gate ───────────────────────────────────────────────
SLIPPAGE_GATE_BUFFER_BPS=50      # abort submit if re-quote within X bps of min

# ─── Observability ───────────────────────────────────────────────
HEALTH_PORT=4002                 # /health + /metrics
KEEPER_INSTANCE_ID=keeper-0      # tag for multi-keeper deployments

# ─── Discord webhook for stuck-pipeline alerts (optional) ─────────
ALERT_DISCORD_WEBHOOK=
ALERT_PIPELINE_STUCK_MIN=10

# ─── Sentry (optional) ───────────────────────────────────────────
SENTRY_DSN=
SENTRY_RELEASE=
