# ─── Database ────────────────────────────────────────────────────
DATABASE_URL="postgresql://polyorder:polyorder@localhost:5432/polyorder"

# ─── Chain ───────────────────────────────────────────────────────
CHAIN_ID=80002
RPC_URL="http://127.0.0.1:8545"                        # Anvil fork (local) or public RPC

# Private mempool — only matters on real mainnet. Submitting through a
# private RPC hides our tx from public mempool, so MEV bots can't see and
# front-run / sandwich. Reads stay on the public RPC.
#
# Polygon options (Phase 4 / production):
#   https://polygon.fastlane.xyz       # Polygon FastLane (MEV-Share style)
#   https://rpc.mevblocker.io           # MEV-Blocker.io (Flashbots-style)
#   https://rpc.marlin.org              # Marlin Protocol private RPC
#
# Leave empty on local Anvil — Anvil has no real mempool.
PRIVATE_RPC_URL=""

# ─── Keeper signer ───────────────────────────────────────────────
# Must match an authorized keeper in LimitOrderRouter (setKeeperAuthorization)
KEEPER_PRIVATE_KEY="0x..."

# ─── Contract ────────────────────────────────────────────────────
LIMIT_ORDER_ROUTER_ADDRESS="0x095Bb278B387511DCaD7F1705cfb8951bfDFa59c"

# ─── 1inch API ───────────────────────────────────────────────────
# Get a key at https://portal.1inch.dev
# Leave empty to use mock prices (useful for testnet / dry-run)
ONEINCH_API_KEY=""

# ─── Keeper settings ─────────────────────────────────────────────
POLL_INTERVAL_SECONDS=2      # how often to poll for triggered orders
MAX_CONCURRENT_ORDERS=5      # max parallel order executions per cycle
DRY_RUN=true                 # when true: check triggers but skip tx submission
LOG_LEVEL=info
