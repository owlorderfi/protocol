# Base Sepolia chain-specific config.
# Source AFTER `.env` (common): `source .env && source .env.base-sepolia`
#
# Per-chain overrides go here too — e.g. if Base mainnet uses a different
# DEPLOYER_PRIVATE_KEY or INITIAL_OWNER (multisig), put them in `.env.base`
# and they'll win because `.env.<chain>` is sourced last.

# RPC endpoint for Base Sepolia. Public works for ad-hoc; use a paid
# provider (Alchemy, Quicknode) for keeper / production loads.
BASE_SEPOLIA_RPC=https://sepolia.base.org

# BaseScan API key (separate from Etherscan V2). Empty = skip --verify.
# Get one at https://basescan.org/myapikey
BASESCAN_API_KEY=

# Filled after deployment for reference. The keeper / api / web envs
# also have their own copy (CHAIN_84532_ROUTER) — keep them in sync.
LIMIT_ORDER_ROUTER_ADDRESS=
