// Polyorder DB schema
// Run: pnpm --filter @owlorderfi/api prisma:migrate

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users (wallet-authenticated) ──────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  walletAddress String  @unique @db.VarChar(42)
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime @default(now())

  // 1:N
  orders          Order[]
  scheduledOrders ScheduledOrder[]
  nonces          AuthNonce[]
  sessions        Session[]

  @@index([walletAddress])
  @@map("users")
}

// ─── Auth: nonces for SIWE-style login ──────────────────────────────

model AuthNonce {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  nonce     String   @db.VarChar(64)
  consumed  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([nonce])
  @@index([userId])
  @@map("auth_nonces")
}

// ─── Auth: issued JWT sessions (revocable) ─────────────────────────

model Session {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String   @unique @db.VarChar(128)
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  // Note: userAgent + ipAddress columns intentionally NOT present —
  // dropped 2026-05-25 for privacy by design (they were never
  // populated and we have client IPs in Caddy access logs anyway,
  // which is enough for abuse mitigation).

  @@index([userId])
  @@map("sessions")
}

// ─── Orders ────────────────────────────────────────────────────────

enum OrderType {
  LIMIT_BUY
  LIMIT_SELL
  STOP_LOSS
  TAKE_PROFIT
}

enum OrderStatus {
  OPEN
  EXECUTING   // transient: keeper locked the order and is submitting tx
  FILLED
  CANCELLED
  EXPIRED
  FAILED
}

model Order {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @db.Uuid
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  chainId   Int
  maker     String      @db.VarChar(42)
  tokenIn   String      @db.VarChar(42)
  tokenOut  String      @db.VarChar(42)

  // bigint as string (Postgres numeric not used to keep simple JSON serialization)
  amountIn         String @db.VarChar(80)
  minAmountOut     String @db.VarChar(80)
  triggerPrice     String @db.VarChar(80)

  orderType OrderType
  status    OrderStatus @default(OPEN)

  // Per-order protocol fee in basis points. Signed by maker, capped on-chain.
  feeBps    Int         @default(30)

  // EIP-712 signature
  nonce     String @db.VarChar(80)
  signature String @db.VarChar(132)

  deadline    DateTime
  createdAt   DateTime  @default(now())
  executingAt DateTime?
  filledAt    DateTime?

  // Transient-failure retry accounting (slippage gate, gas spike, re-quote
  // error). releaseLock bumps retryCount + stamps lastFailedAt; the poller
  // backs off LIMIT_RETRY_BACKOFF_SEC between attempts and escalates the
  // order to FAILED once retryCount reaches LIMIT_MAX_RETRIES.
  retryCount   Int       @default(0)
  lastFailedAt DateTime?

  // On-chain reference (set when keeper submits tx; updated to FILLED/FAILED on receipt)
  txHash           String? @db.VarChar(66)
  filledAmountOut  String? @db.VarChar(80)
  failureReason    String? @db.VarChar(500)
  // Uniswap V3 fee tier the keeper picked for this fill (100/500/3000/10000)
  feeTier          Int?
  // Polyorder protocol fee actually paid (in tokenOut wei). Pulled from
  // OrderExecuted event; lets the UI show the fee breakdown without making
  // assumptions about feeBps.
  feeAmount        String? @db.VarChar(80)

  // ─── Ladder grouping ─────────────────────────────────────────────
  // When a maker creates a take-profit ladder (N independent limit
  // orders at staggered prices, signed in one UX flow), each rung gets
  // a separate Order row sharing the same ladderId. ladderRungIndex
  // gives the rendering order within the group (0..N-1).
  //
  // null/null = standalone limit order (the default — pre-ladder
  // behavior). A non-null ladderId implies a non-null rung index;
  // enforce that in the API DTO since Prisma doesn't model the
  // dependency. ladderRungIndex is just for display ordering — the
  // contract doesn't know or care; each row is a normal LIMIT_BUY /
  // LIMIT_SELL the keeper executes via executeOrder.
  ladderId         String? @db.Uuid
  ladderRungIndex  Int?

  @@index([userId, status])
  @@index([status, deadline])
  @@index([status, executingAt])
  @@index([maker, chainId])
  @@index([ladderId])
  @@map("orders")
}

// ─── Scheduled orders (DCA + TWAP) ────────────────────────────────

enum ScheduledOrderStatus {
  ACTIVE      // keeper is executing slices on schedule
  COMPLETED   // maxSlices reached, no more executions
  EXPIRED     // endTime crossed without completion
  CANCELLED   // maker invalidated the nonce on-chain
}

enum ScheduledExecutionStatus {
  PENDING     // keeper reserved this slot, tx not yet confirmed
  FILLED      // on-chain confirmation received
  FAILED      // tx reverted; slot is reusable on next tick
}

/// ScheduledOrder backs both DCA and TWAP. Difference is config:
///   DCA  → endTime = epoch 0, maxSlices = 0 (open-ended, recurring)
///   TWAP → endTime > 0, maxSlices > 0, short intervalSec
model ScheduledOrder {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  chainId  Int
  maker    String @db.VarChar(42)
  tokenIn  String @db.VarChar(42)
  tokenOut String @db.VarChar(42)

  amountPerSlice String @db.VarChar(80) // bigint as string
  intervalSec    Int    // seconds between slices, ≥ MIN_INTERVAL_SEC (60)
  startTime      DateTime
  endTime        DateTime? // null = open-ended (DCA)
  maxSlices      Int    // 0 = unbounded (DCA mode); contract caps at 10_000
  maxSlippageBps Int    // per-slice slippage tolerance vs keeper quote
  // Maker-signed hard price floor (tokenOut human per 1 tokenIn human × 1e18).
  // "0" = floor disabled (maker opted out). Contract reads decimals on-chain
  // and converts to raw minOut. Stored as string for arbitrary-precision bigint.
  minPriceScaled String @db.VarChar(80) @default("0")
  feeBps         Int    // signed by maker, capped at 100 on-chain

  // EIP-712 signature material
  nonce     String   @db.VarChar(80)
  signature String   @db.VarChar(132)
  deadline  DateTime // signature deadline (not order deadline)

  status         ScheduledOrderStatus  @default(ACTIVE)
  // Cached on-chain counters refreshed by the keeper after each slice
  slicesExecuted Int                   @default(0)
  lastExecutedAt DateTime?

  createdAt    DateTime  @default(now())
  cancelledAt  DateTime?

  executions ScheduledExecution[]

  @@index([userId, status])
  @@index([status, lastExecutedAt]) // keeper poll: find due orders
  @@index([maker, chainId])
  @@map("scheduled_orders")
}

/// One row per attempted slice. Keeper writes PENDING when reserving the
/// slot, updates to FILLED/FAILED once the receipt arrives.
model ScheduledExecution {
  id String @id @default(uuid()) @db.Uuid

  scheduledOrderId String         @db.Uuid
  scheduledOrder   ScheduledOrder @relation(fields: [scheduledOrderId], references: [id], onDelete: Cascade)

  sliceIndex Int                       // 0-based, matches event.sliceIndex
  status     ScheduledExecutionStatus  @default(PENDING)

  txHash         String? @db.VarChar(66)
  amountIn       String? @db.VarChar(80) // bigint
  amountOut      String? @db.VarChar(80)
  feeAmount      String? @db.VarChar(80)
  failureReason  String? @db.VarChar(500)
  // Only meaningful when status=FAILED. Permanent failures (invalid
  // signature, deadline expired, order cancelled on-chain, insufficient
  // maker balance/allowance) block all future retries for this slot.
  // Transient failures (BREAK_EVEN_SKIP, GasTooHigh, RPC error) leave
  // this false → poller retries after SCHEDULED_RETRY_BACKOFF_SEC.
  permanent Boolean @default(false)

  executedAt DateTime @default(now())

  // No @@unique on (orderId, sliceIndex) — replaced by a PARTIAL unique
  // index in the migration SQL that constrains only PENDING/FILLED rows.
  // Multiple FAILED rows per slot are allowed so each retry attempt
  // becomes a new row (audit trail of why the slice kept retrying).
  // The partial index still catches concurrent-worker double-execute
  // races on the active slot.
  @@index([scheduledOrderId, status])
  @@index([scheduledOrderId, sliceIndex, executedAt])
  @@map("scheduled_executions")
}

// ─── Monitoring / SysGuard port ───────────────────────────────────
//
// Periodic snapshots of server health + traffic patterns, used by the
// admin monitoring panel (B-Bundle in docs/pre-mainnet-hardening-plan.md).
// Each snapshot captures a point-in-time view of Caddy access log
// patterns over the last hour: total request count, unique source IPs,
// and a list of "suspicious" IPs that triggered detection rules
// (HIGH_RATE / BOT_UA / PATH_SCANNING / HIGH_ERRORS — see Caddy collector).
//
// Scheduler writes one row every 15 min. Retention 30 days (clean-up via
// MonitoringService.cleanupOldSnapshots() cron). Detection logic that
// banned-IP / threshold-alerting fed off this table comes in B-Bundle 2.

model MonitoringSnapshot {
  id          String   @id @default(uuid()) @db.Uuid
  collectedAt DateTime @default(now())

  totalRequests1h  Int    @default(0)
  uniqueIps1h      Int    @default(0)

  // suspiciousIps: array of { ip, requests_1h, unique_paths, errors,
  // error_pct, user_agent, flags[] }. Stored as JSON so the detection
  // shape can evolve without a migration each time.
  suspiciousIps Json @default("[]")

  // Full snapshot dump for replay / debug.
  raw Json @default("{}")

  @@index([collectedAt])
  @@map("monitoring_snapshots")
}

// ─── Pool spot snapshots (for longer-horizon trends) ──────────────
//
// 5-minute interval snapshots of the canonical spot price for every
// active pair on every active mainnet chain. Powers the Smart Suggest's
// 1-hour drift projection (we only need ≤4h of history to derive a 1h
// trend; the wider Wait pills — 1d — set drift=0 by design because
// linear projection over a day is fortune-telling).
//
// `priceScaled` is the canonical tokenOut-per-tokenIn ratio × 1e18,
// same shape the keeper + market service already produce. Stored as
// string because it's a 256-bit number on the wire.
//
// Retention 7 days, pruned via a cron in MarketSnapshotService. Storage
// footprint is trivial — ~12 snapshots/h × 24h × 7d × ~10 pairs ×
// 2 chains ≈ 40k rows, well under 10 MB on disk.
model PoolSpotSnapshot {
  chainId      Int      @map("chain_id")
  tokenIn      String   @map("token_in")  @db.Char(42)
  tokenOut     String   @map("token_out") @db.Char(42)
  priceScaled  String   @map("price_scaled") @db.VarChar(80)
  ts           DateTime

  @@id([chainId, tokenIn, tokenOut, ts])
  // Hot path: "give me the snapshot closest to (now - 1h)" — descending-ts
  // index lookup against this scan.
  @@index([chainId, tokenIn, tokenOut, ts(sort: Desc)])
  @@map("pool_spot_snapshots")
}
