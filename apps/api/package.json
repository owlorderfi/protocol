    "@nestjs/platform-fastify": "^11.0.5",
    "@owlorderfi/shared": "workspace:*",
    "@prisma/client": "^6.2.1",
    "@sentry/node": "^10.53.1",
    "fastify": "^5.8.5",
    "nestjs-zod": "^4.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "viem": "^2.22.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.5",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "prisma": "^6.2.1",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
