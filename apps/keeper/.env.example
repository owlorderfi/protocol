# ─── Database ────────────────────────────────────────────────────
DATABASE_URL="postgresql://polyorder:polyorder@localhost:5432/polyorder"

# ─── Chain ───────────────────────────────────────────────────────
# Supported: 31337 (Anvil fork), 137 (Polygon mainnet), 84532 (Base Sepolia)
# Amoy (80002) has no official Uniswap V3 — keeper cannot operate there.
#
# Pick the RPC matching CHAIN_ID:
#   31337 → http://127.0.0.1:8545
#   137   → https://polygon-rpc.com  (or paid Alchemy/Infura)
#   84532 → https://sepolia.base.org  (or Coinbase / Alchemy)
CHAIN_ID=31337
RPC_URL="http://127.0.0.1:8545"

# Private mempool — only matters on real mainnet. Submitting through a
# private RPC hides our tx from public mempool, so MEV bots can't see and
# front-run / sandwich. Reads stay on the public RPC.
#
# Polygon options (Phase 4 / production):
#   https://polygon.fastlane.xyz       # Polygon FastLane (MEV-Share style)
#   https://rpc.mevblocker.io           # MEV-Blocker.io (Flashbots-style)
#   https://rpc.marlin.org              # Marlin Protocol private RPC
#
# Leave empty on local Anvil — Anvil has no real mempool.
PRIVATE_RPC_URL=""

# ─── Keeper signer ───────────────────────────────────────────────
# Must match an authorized keeper in LimitOrderRouter (setKeeperAuthorization)
KEEPER_PRIVATE_KEY="0x..."

# ─── Contract ────────────────────────────────────────────────────
LIMIT_ORDER_ROUTER_ADDRESS="0x095Bb278B387511DCaD7F1705cfb8951bfDFa59c"

# ─── 1inch API ───────────────────────────────────────────────────
# Get a key at https://portal.1inch.dev
# Leave empty to use mock prices (useful for testnet / dry-run)
ONEINCH_API_KEY=""

# ─── Keeper settings ─────────────────────────────────────────────
POLL_INTERVAL_SECONDS=2          # how often to poll for triggered orders
MAX_CONCURRENT_ORDERS=5          # max parallel order executions per cycle
STUCK_EXECUTING_MINUTES=5        # threshold for stuck-order recovery
DRY_RUN=true                     # when true: check triggers but skip tx
LOG_LEVEL=info

# ─── Gas + tx replacement (Phase 4) ──────────────────────────────
GAS_HEADROOM_MULT=1.5            # maxFee = baseFee × this + priority
GAS_BUMP_PCT=20                  # +X% gas on stuck-tx replacement
TX_REPLACE_AFTER_SEC=60          # wait this long before bumping

# ─── Slippage gate ───────────────────────────────────────────────
SLIPPAGE_GATE_BUFFER_BPS=50      # abort submit if re-quote within X bps of min

# ─── Observability ───────────────────────────────────────────────
HEALTH_PORT=4002                 # /health + /metrics
KEEPER_INSTANCE_ID=keeper-0      # tag for multi-keeper deployments

# ─── Discord webhook for stuck-pipeline alerts (optional) ─────────
ALERT_DISCORD_WEBHOOK=
ALERT_PIPELINE_STUCK_MIN=10

# ─── WebSocket RPC for low-latency triggers (optional) ───────────
# Example: wss://polygon-mainnet.g.alchemy.com/v2/<KEY>
WS_RPC_URL=

# ─── Sentry (optional) ───────────────────────────────────────────
# Create a Node project at sentry.io → Settings → Client Keys (DSN).
# When empty, the keeper logs but does not ship telemetry.
SENTRY_DSN=
SENTRY_RELEASE=
