# ───────────────────────────────────────────────────────────────────
# Per-chain env layout
# ───────────────────────────────────────────────────────────────────
# This template covers the SHARED `.env` (common across chains).
# Chain-specific values live in `.env.<chain>` files — see
# `.env.base-sepolia.example` for the chain-side template.
#
# Deploy invocation:
#     source .env && source .env.base-sepolia && forge script \
#         script/DeployLimitOrderRouter.s.sol --rpc-url base_sepolia \
#         --broadcast --verify -vvv
#
# Later `source` wins — a per-chain file can override INITIAL_OWNER /
# DEPLOYER_PRIVATE_KEY when a chain needs a different multisig or
# deployer (e.g. testnet vs mainnet).
# ───────────────────────────────────────────────────────────────────

# Deployer + initial wallets (used by DeployLimitOrderRouter.s.sol)
# TESTNET ONLY in plain text; use keystore for mainnet.
DEPLOYER_PRIVATE_KEY=
INITIAL_OWNER=
INITIAL_FEE_RECIPIENT=
INITIAL_KEEPER=
INITIAL_FEE_BPS=25

# Scanner / explorer API keys (shared across chains)
# Etherscan V2 unified key (works for Polygonscan + Amoy via the same endpoint)
ETHERSCAN_API_KEY=
# Polygonscan legacy key (fallback for older flows)
POLYGONSCAN_KEY=
# Chainstack — only if you proxy public RPCs through them
CHAINSTACK_API_KEY=
