NODE_ENV=development
API_PORT=3001

# Database
DATABASE_URL=postgresql://polyorder:polyorder@localhost:5432/polyorder?schema=public

# JWT — minimum 32 chars, rotate in production
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-long-random-string-min-32-chars
JWT_EXPIRES_IN=24h

# Login domain shown in the message users sign during /auth/login
LOGIN_DOMAIN=polyorder.local

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Chain RPC (read-only, server-side)
POLYGON_RPC=https://polygon-rpc.com
AMOY_RPC=https://rpc-amoy.polygon.technology

# ─── Sentry (optional) ───────────────────────────────────────────
# Leave empty to disable telemetry (sane default for dev / local).
# Create a Node project at sentry.io → Settings → Client Keys (DSN).
SENTRY_DSN=
# Optional: lets Sentry group errors by release. Set to git SHA on
# deploy; safe to leave empty otherwise.
SENTRY_RELEASE=
